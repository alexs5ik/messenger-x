# Copy to `.env` and adjust. Loaded by mx-server at startup.
MX_BIND_ADDR=127.0.0.1:9990
DATABASE_URL=postgres://mx:mx@localhost:5432/messenger_x
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
NATS_URL=nats://localhost:4222
CLICKHOUSE_URL=http://localhost:8123
# Server-issued token signing secret (dev only — use a managed secret in prod).
MX_TOKEN_SECRET=dev-insecure-change-me
RUST_LOG=info,mx_server=debug
